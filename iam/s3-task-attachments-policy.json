{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadWriteTaskAttachments",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::REPLACE_WITH_BUCKET_NAME/tasks/*"
    },
    {
      "Sid": "ListBucketScopedToTasksPrefix",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::REPLACE_WITH_BUCKET_NAME",
      "Condition": {
        "StringLike": {
          "s3:prefix": ["tasks/*"]
        }
      }
    }
  ]
}
