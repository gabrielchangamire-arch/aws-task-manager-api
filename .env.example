# Local SQLite by default. Switch to Postgres locally with the docker-compose db,
# or to AWS RDS Postgres in production.
# Examples:
#   sqlite:///./tasks.db
#   postgresql+psycopg://taskuser:taskpass@localhost:5432/tasks
#   postgresql+psycopg://USER:PASS@your-rds-endpoint.amazonaws.com:5432/tasks
DATABASE_URL=sqlite:///./tasks.db

# App config
APP_ENV=development
LOG_LEVEL=INFO

# Comma-separated list of allowed CORS origins. Defaults cover the local
# Vite dev server. Add your production front-end URL here when deployed.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AWS / S3 (only required if you enable S3 attachments)
S3_ENABLED=false
AWS_REGION=us-west-2
S3_BUCKET_NAME=
# Leave AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY unset when running on EC2
# with an IAM role attached. Set them only for local development.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
